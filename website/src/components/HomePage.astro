                    {badge.shape === "square" && <rect x="4" y="4" width="20" height="20" rx="3" fill={badge.unlocked ? "var(--app-orange)" : "none"} stroke="var(--fg3)" stroke-width="1.2"></rect>}
                    {badge.shape === "triangle" && <path d="M14 3 L25 23 L3 23 Z" fill={badge.unlocked ? "#a84a9e" : "none"} stroke="var(--fg3)" stroke-width="1.2" stroke-linejoin="round"></path>}
