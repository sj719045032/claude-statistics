function buildCurvePath(data: number[], width: number, height: number, inset = 10) {
  const max = Math.max(...data);
  const min = Math.min(...data);
  const dx = width / Math.max(data.length - 1, 1);
  return data
    .map((value, index) => {
      const x = index * dx;
      const normalized = (value - min) / Math.max(max - min, 1);
      const y = height - normalized * (height - inset * 2) - inset;
      return `${index === 0 ? "M" : "L"} ${x.toFixed(1)} ${y.toFixed(1)}`;
    })
    .join(" ");
}

const areaPath = buildCurvePath(chartData, 600, 180);
const miniTrendPath = buildCurvePath(trendData, 440, 100, 8);
const miniUsagePath = buildCurvePath(chartData.slice(0, 10), 220, 30, 4);

function buildHeatmapCells() {
  const cells: number[] = [];
  let seed = 42;
  const rand = () => {
    seed = (seed * 9301 + 49297) % 233280;
    return seed / 233280;
  };

  for (let index = 0; index < 53 * 7; index += 1) {
    const weekIdx = Math.floor(index / 7);
    const day = index % 7;
    const recency = weekIdx / 53;
    const weekend = day === 5 || day === 6 ? 0.6 : 1;
    const base = rand() * weekend * (0.45 + recency * 0.85);
    let level = 0;
    if (base > 0.72) level = 4;
    else if (base > 0.52) level = 3;
    else if (base > 0.32) level = 2;
    else if (base > 0.15) level = 1;
    cells.push(level);
  }

  return cells;
}

