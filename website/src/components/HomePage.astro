  <script is:inline>
    (() => {
      const repoApi = "https://api.github.com/repos/sj719045032/claude-statistics";
      const latestReleaseApi = "https://api.github.com/repos/sj719045032/claude-statistics/releases/latest";

      const versionNodes = Array.from(document.querySelectorAll("[data-github-version]"));
      const starNodes = Array.from(document.querySelectorAll("[data-github-stars]"));
      const updatedNodes = Array.from(document.querySelectorAll("[data-github-updated]"));

      const formatRelative = (iso, lang) => {
        const date = new Date(iso);
        if (Number.isNaN(date.getTime())) return null;
        const diff = Math.max(0, Date.now() - date.getTime());
        const min = Math.floor(diff / 60000);
        const hr = Math.floor(diff / 3600000);
        const day = Math.floor(diff / 86400000);
        const mon = Math.floor(day / 30);
        const isZh = lang === "zh";
        if (min < 1) return isZh ? "刚刚" : "just now";
        if (min < 60) return isZh ? `${min} 分钟前` : `${min}m ago`;
        if (hr < 24) return isZh ? `${hr} 小时前` : `${hr}h ago`;
        if (day < 30) return isZh ? `${day} 天前` : `${day}d ago`;
        return isZh ? `${mon} 个月前` : `${mon}mo ago`;
      };

      Promise.allSettled([
        fetch(repoApi).then((response) => response.ok ? response.json() : null),
        fetch(latestReleaseApi).then((response) => response.ok ? response.json() : null)
      ]).then((results) => {
        const repo = results[0]?.status === "fulfilled" ? results[0].value : null;
        const latest = results[1]?.status === "fulfilled" ? results[1].value : null;

        if (latest?.tag_name) {
          versionNodes.forEach((node) => {
            node.textContent = latest.tag_name;
          });
        }

        if (typeof repo?.stargazers_count === "number") {
          starNodes.forEach((node) => {
            node.textContent = `${repo.stargazers_count} ★`;
          });
        }

        if (latest?.published_at) {
          updatedNodes.forEach((node) => {
            const label = formatRelative(latest.published_at, node.dataset.lang);
            if (label) node.textContent = label;
          });
        }
      });

      const poster = document.querySelector("[data-share-poster]");
      const roleNode = document.querySelector("[data-share-role-value]");
      const subNode = document.querySelector("[data-share-sub-value]");
      const noteNode = document.querySelector("[data-share-note-value]");
      const matchLabels = Array.from(document.querySelectorAll("[data-share-match-label]"));
      const matchPcts = Array.from(document.querySelectorAll("[data-share-match-pct]"));
      const matchBars = Array.from(document.querySelectorAll("[data-share-match-bar]"));
      const themeButtons = Array.from(document.querySelectorAll("[data-share-trigger]"));

      if (!poster || !roleNode || !subNode || !noteNode || themeButtons.length === 0) return;

      const applyTheme = (button) => {
        const background = button.dataset.shareBackground;
        const role = button.dataset.shareRole;
        const sub = button.dataset.shareSub;
        const note = button.dataset.shareNote;
        const matches = JSON.parse(button.dataset.shareMatches || "[]");

        if (background) poster.style.background = background;
        if (role) roleNode.textContent = role;
        if (sub) subNode.textContent = sub;
        if (note) noteNode.textContent = note;

        matches.slice(0, 3).forEach((match, index) => {
          if (matchLabels[index]) matchLabels[index].textContent = match.label;
          if (matchPcts[index]) matchPcts[index].textContent = match.pct;
          if (matchBars[index]) matchBars[index].style.width = match.pct;
        });

        themeButtons.forEach((item) => {
          item.style.background = "transparent";
          item.style.color = "var(--fg2)";
        });
        button.style.background = "var(--ink)";
        button.style.color = "#f7f4ed";
      };

      themeButtons.forEach((button) => {
        button.addEventListener("click", () => applyTheme(button));
      });
    })();
  </script>
